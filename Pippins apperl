<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pip Pins Apparel | Fresh Finds, Best Price</title>
    <!-- Tailwind CSS for modern, clean design -->
