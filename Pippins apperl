</head>
<body class="bg-gray-50 text-gray-900 font-sans antialiased">

    <!-- Navbar -->
    <nav class="sticky top-0 z-40 bg-white/90 backdrop-blur-md shadow-xs border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            <div>
                <span class="text-xl font-black tracking-tight text-indigo-600">PIP PINS</span>
                <span class="text-xl font-light text-gray-500"> APPAREL</span>
            </div>
            <div class="text-sm font-medium text-gray-500 hidden sm:block italic">
                "Fresh Finds, Best Price"
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <header class="relative w-full h-[70vh] sm:h-[85vh] bg-gray-900 flex items-center justify-center overflow-hidden">
        <!-- Hero Image Backdrop -->
        <img src="https://i.ibb.co/xtCpqt12/Picsart-26-07-11-03-30-22-015.jpg" alt="Pip Pins Apparel Hero" class="absolute inset-0 w-full h-full object-cover opacity-60 pointer-events-none">
        <!-- Gradient Overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-950/40 to-transparent"></div>
        
        <!-- Hero Content -->
        <div class="relative z-10 text-center px-4 max-w-3xl">
            <span class="inline-block text-xs uppercase tracking-widest bg-indigo-600 text-white font-semibold px-3 py-1 rounded-full mb-4 shadow-sm">New Collection 2026</span>
            <h1 class="text-4xl sm:text-6xl font-extrabold text-white tracking-tight drop-shadow-md mb-3">
                Upgrade Your Style
            </h1>
            <p class="text-lg sm:text-xl text-gray-200 mb-8 font-medium max-w-xl mx-auto drop-shadow-xs">
                Fresh Finds, Best Price. Handpicked premium apparel tailored just for you.
            </p>
            <a href="#products-section" class="inline-flex items-center justify-center bg-white text-gray-900 hover:bg-indigo-600 hover:text-white font-semibold px-8 py-3.5 rounded-xl transition-all duration-300 transform hover:-translate-y-0.5 shadow-lg gap-2 group">
                Shop Now 
                <i class="fa-solid fa-arrow-down transition-transform group-hover:translate-y-1"></i>
            </a>
        </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        
        <!-- Products Section -->
        <section id="products-section" class="mb-16 scroll-mt-20">
            <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-8">
                <div>
                    <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 tracking-tight">Featured Products</h2>
                    <p class="text-gray-500 text-sm mt-1">Swipe or use scroll to explore our latest entries.</p>
                </div>
                <div class="flex gap-2 mt-4 sm:mt-0">
                    <button onclick="scrollCarousel(-1)" class="w-10 h-10 rounded-full border border-gray-200 bg-white flex items-center justify-center text-gray-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors shadow-xs cursor-pointer">
                        <i class="fa-solid fa-chevron-left"></i>
                    </button>
                    <button onclick="scrollCarousel(1)" class="w-10 h-10 rounded-full border border-gray-200 bg-white flex items-center justify-center text-gray-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors shadow-xs cursor-pointer">
                        <i class="fa-solid fa-chevron-right"></i>
                    </button>
                </div>
            </div>

            <!-- Product Carousel Container -->
            <div id="product-carousel" class="flex gap-6 overflow-x-auto snap-x snap-mandatory no-scrollbar pb-6 scroll-smooth">
                <!-- Product Card 1 -->
                <div class="min-w-[280px] sm:min-w-[320px] max-w-[320px] snap-start bg-white rounded-2xl border border-gray-100 shadow-xs hover:shadow-md transition-shadow duration-300 flex flex-col overflow-hidden group">
                    <div class="relative aspect-square bg-gray-100 overflow-hidden">
                        <img src="https://i.ibb.co/3YM0cY9f/AISelect-20260712-155246.jpg" alt="Classic Denim Jacket" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                    </div>
                    <div class="p-5 flex flex-col flex-1">
                        <h3 class="font-bold text-gray-900 text-lg mb-1 line-clamp-1">Classic Denim Jacket</h3>
                        <p class="text-indigo-600 font-extrabold text-xl mb-4">₹1,499</p>
                        <button onclick="addToCart('Classic Denim Jacket', 1499, 'https://i.ibb.co/3YM0cY9f/AISelect-20260712-155246.jpg')" class="mt-auto w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2.5 px-4 rounded-xl transition-colors duration-200 flex items-center justify-center gap-2 cursor-pointer">
                            <i class="fa-solid fa-cart-plus"></i> Add to Cart
                        </button>
                    </div>
                </div>

                <!-- Product Card 2 -->
                <div class="min-w-[280px] sm:min-w-[320px] max-w-[320px] snap-start bg-white rounded-2xl border border-gray-100 shadow-xs hover:shadow-md transition-shadow duration-300 flex flex-col overflow-hidden group">
                    <div class="relative aspect-square bg-gray-100 overflow-hidden">
                        <img src="https://i.ibb.co/LDqvs4nv/AISelect-20260714-203130.jpg" alt="Urban Oversized Hoodie" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                    </div>
                    <div class="p-5 flex flex-col flex-1">
                        <h3 class="font-bold text-gray-900 text-lg mb-1 line-clamp-1">Urban Oversized Hoodie</h3>
                        <p class="text-indigo-600 font-extrabold text-xl mb-4">₹1,199</p>
                        <button onclick="addToCart('Urban Oversized Hoodie', 1199, 'https://i.ibb.co/LDqvs4nv/AISelect-20260714-203130.jpg')" class="mt-auto w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2.5 px-4 rounded-xl transition-colors duration-200 flex items-center justify-center gap-2 cursor-pointer">
                            <i class="fa-solid fa-cart-plus"></i> Add to Cart
                        </button>
                    </div>
                </div>

                <!-- Product Card 3 -->
                <div class="min-w-[280px] sm:min-w-[320px] max-w-[320px] snap-start bg-white rounded-2xl border border-gray-100 shadow-xs hover:shadow-md transition-shadow duration-300 flex flex-col overflow-hidden group">
                    <div class="relative aspect-square bg-gray-100 overflow-hidden">
                        <img src="https://i.ibb.co/qLynHsBm/AISelect-20260712-164410.jpg" alt="Vintage Checked Shirt" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                    </div>
                    <div class="p-5 flex flex-col flex-1">
                        <h3 class="font-bold text-gray-900 text-lg mb-1 line-clamp-1">Vintage Checked Shirt</h3>
                        <p class="text-indigo-600 font-extrabold text-xl mb-4">₹899</p>
                        <button onclick="addToCart('Vintage Checked Shirt', 899, 'https://i.ibb.co/qLynHsBm/AISelect-20260712-164410.jpg')" class="mt-auto w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2.5 px-4 rounded-xl transition-colors duration-200 flex items-center justify-center gap-2 cursor-pointer">
                            <i class="fa-solid fa-cart-plus"></i> Add to Cart
                        </button>
                    </div>
                </div>

                <!-- Product Card 4 -->
                <div class="min-w-[280px] sm:min-w-[320px] max-w-[320px] snap-start bg-white rounded-2xl border border-gray-100 shadow-xs hover:shadow-md transition-shadow duration-300 flex flex-col overflow-hidden group">
                    <div class="relative aspect-square bg-gray-100 overflow-hidden">
                        <img src="https://i.ibb.co/WpxZ7GBn/1d1a2b4057641bdfaad0447bbda3725b.jpg" alt="Premium Comfort Chinos" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                    </div>
                    <div class="p-5 flex flex-col flex-1">
                        <h3 class="font-bold text-gray-900 text-lg mb-1 line-clamp-1">Premium Comfort Chinos</h3>
                        <p class="text-indigo-600 font-extrabold text-xl mb-4">₹1,299</p>
                        <button onclick="addToCart('Premium Comfort Chinos', 1299, 'https://i.ibb.co/WpxZ7GBn/1d1a2b4057641bdfaad0447bbda3725b.jpg')" class="mt-auto w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2.5 px-4 rounded-xl transition-colors duration-200 flex items-center justify-center gap-2 cursor-pointer">
                            <i class="fa-solid fa-cart-plus"></i> Add to Cart
                        </button>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!-- Footer / Contact Info -->
    <footer class="bg-gray-900 text-gray-400 py-12 border-t border-gray-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-6">
            <div>
                <h3 class="text-white font-bold text-lg">Pip Pins Apparel</h3>
                <p class="text-sm mt-1">Fresh Finds, Best Price</p>
            </div>
            <div class="text-sm text-center sm:text-right">
                <p><i class="fa-solid fa-envelope text-indigo-400 mr-2"></i>pritamsen850@gmail.com</p>
                <p class="mt-2 text-xs text-gray-500">&copy; 2026 Pip Pins Apparel. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <!-- Floating Action Buttons Layer -->
    <div class="fixed bottom-6 right-6 z-40 flex flex-col gap-3.5">
        <!-- Floating WhatsApp Button -->
        <a href="https://wa.me/7449597053?text=Hi!%20I'm%20interested%20in%20your%20apparel%20collection." target="_blank" rel="noopener noreferrer" class="w-14 h-14 bg-[#25D366] text-white rounded-full flex items-center justify-center shadow-xl hover:scale-110 transition-transform duration-200 cursor-pointer" title="Chat on WhatsApp">
            <i class="fa-brands fa-whatsapp text-3xl"></i>
        </a>

        <!-- Floating Cart Icon -->
        <button onclick="toggleCartDrawer(true)" class="relative w-14 h-14 bg-indigo-600 text-white rounded-full flex items-center justify-center shadow-xl hover:scale-110 transition-transform duration-200 cursor-pointer" title="View Cart">
            <i class="fa-solid fa-bag-shopping text-2xl"></i>
            <span id="cart-badge" class="absolute -top-1 -right-1 bg-rose-500 text-white text-xs font-bold w-6 h-6 rounded-full flex items-center justify-center scale-0 transition-transform duration-200">0</span>
        </button>
    </div>

    <!-- Cart Drawer Modal Overlay -->
    <div id="cart-overlay" class="fixed inset-0 bg-black/50 z-50 opacity-0 pointer-events-none transition-opacity duration-300" onclick="toggleCartDrawer(false)">
        <!-- Sidebar Drawer Content -->
        <div class="absolute right-0 top-0 h-full w-full max-w-md bg-white shadow-2xl flex flex-col transform translate-x-full transition-transform duration-300 overflow-hidden" onclick="event.stopPropagation()">
            <!-- Drawer Header -->
            <div class="p-4 border-b border-gray-100 flex items-center justify-between bg-gray-50">
                <div class="flex items-center gap-2">
                    <i class="fa-solid fa-bag-shopping text-indigo-600 text-xl"></i>
                    <h2 class="text-lg font-bold text-gray-900">Your Shopping Bag</h2>
                </div>
                <button onclick="toggleCartDrawer(false)" class="text-gray-400 hover:text-gray-600 p-2 cursor-pointer">
                    <i class="fa-solid fa-xmark text-xl"></i>
                </button>
            </div>

            <!-- Drawer Body / Dynamic Cart Items -->
            <div id="cart-items-container" class="flex-1 overflow-y-auto p-4 space-y-4">
                <!-- Fallback empty text populated by JS -->
            </div>

            <!-- Checkout / Order Form Section -->
            <div id="checkout-section" class="border-t border-gray-100 bg-gray-50 p-4 space-y-4 hidden">
                <div class="flex justify-between items-center text-gray-900 font-bold text-lg mb-2">
                    <span>Total Amount:</span>
                    <span id="cart-total-price">₹0</span>
                </div>
                
                <hr class="border-gray-200">
                
                <h3 class="text-sm font-bold text-gray-700 uppercase tracking-wider"><i class="fa-solid fa-truck-fast mr-1.5 text-indigo-600"></i>Delivery Address Details</h3>
                <form id="order-form" onsubmit="handleCheckout(event)" class="space-y-3">
                    <div>
                        <input type="text" id="cust-name" placeholder="Full Name" required class="w-full text-sm p-2.5 border border-gray-200 bg-white rounded-lg focus:outline-hidden focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500">
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                        <input type="tel" id="cust-phone" placeholder="Mobile Number" required class="w-full text-sm p-2.5 border border-gray-200 bg-white rounded-lg focus:outline-hidden focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500">
                        <input type="email" id="cust-email" placeholder="Your Email ID" required class="w-full text-sm p-2.5 border border-gray-200 bg-white rounded-lg focus:outline-hidden focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500">
                    </div>
                        <textarea id="cust-address" placeholder="Complete Delivery Address" rows="2" required class="w-full text-sm p-2.5 border border-gray-200 bg-white rounded-lg focus:outline-hidden focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 resize-none"></textarea>
                    </div>
                    <div>
                        <input type="text" id="cust-pincode" placeholder="Pincode / Postal Code" required class="w-full text-sm p-2.5 border border-gray-200 bg-white rounded-lg focus:outline-hidden focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500">
                    </div>
                    <button type="submit" id="send-order-btn" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-3 px-4 rounded-xl transition-colors duration-200 flex items-center justify-center gap-2 mt-2 shadow-xs cursor-pointer">
                        <i class="fa-solid fa-paper-plane"></i> Send Order via Email
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- JavaScript Engine -->
    <script>
        // Initialize EmailJS with your public key
        (function() {
            // Replace with your real EmailJS Public Key
            emailjs.init("YOUR_PUBLIC_KEY"); 
        })();

        // Global Cart State Array
        let cart = [];

        // Carousel Manual Scroll Action
        function scrollCarousel(direction) {
            const carousel = document.getElementById('product-carousel');
            const scrollAmount = 340; // Approx card width + gap
            carousel.scrollBy({
                left: direction * scrollAmount,
                behavior: 'smooth'
            });
        }

        // Toggle Drawer Visibility Display
        function toggleCartDrawer(open) {
            const overlay = document.getElementById('cart-overlay');
            const drawer = overlay.firstElementChild;
            if (open) {
                overlay.classList.remove('pointer-events-none', 'opacity-0');
                overlay.classList.add('opacity-100');
                drawer.classList.remove('translate-x-full');
            } else {
                overlay.classList.remove('opacity-100');
                overlay.classList.add('opacity-0', 'pointer-events-none');
                drawer.classList.add('translate-x-full');
            }
        }

        // Core Functions: Add Item to Cart
        function addToCart(name, price, img) {
            const existingItem = cart.find(item => item.name === name);
            if (existingItem) {
                existingItem.quantity += 1;
            } else {
                cart.push({ name, price, img, quantity: 1 });
            }
            updateCartUI();
            
            // Auto-open drawer when an item is added to enhance feedback loop
            toggleCartDrawer(true);
        }

        // Update item quantities inside drawer view
        function updateQuantity(name, delta) {
            const idx = cart.findIndex(item => item.name === name);
            if (idx > -1) {
                cart[idx].quantity += delta;
                if (cart[idx].quantity <= 0) {
                    cart.splice(idx, 1);
                }
            }
            updateCartUI();
        }

        // Render Cart Engine UI State
        function updateCartUI() {
            const itemsContainer = document.getElementById('cart-items-container');
            const checkoutSection = document.getElementById('checkout-section');
            const badge = document.getElementById('cart-badge');
            const totalDisplay = document.getElementById('cart-total-price');
            
            // Calculate totals
            const totalCount = cart.reduce((acc, current) => acc + current.quantity, 0);
            const totalPrice = cart.reduce((acc, current) => acc + (current.price * current.quantity), 0);

            // Update floating badge status
            if (totalCount > 0) {
                badge.innerText = totalCount;
                badge.classList.remove('scale-0');
                badge.classList.add('scale-100');
                checkoutSection.classList.remove('hidden');
            } else {
                badge.classList.remove('scale-100');
                badge.classList.add('scale-0');
                checkoutSection.classList.add('hidden');
            }

            // Render items list layout
            if (cart.length === 0) {
                itemsContainer.innerHTML = `
                    <div class="h-64 flex flex-col items-center justify-center text-gray-400 gap-2">
                        <i class="fa-solid fa-basket-shopping text-4xl"></i>
                        <p class="text-sm font-medium">Your shopping bag is completely empty</p>
                    </div>
                `;
                return;
            }

            totalDisplay.innerText = `₹${totalPrice.toLocaleString('en-IN')}`;

            itemsContainer.innerHTML = cart.map(item => `
                <div class="flex items-center gap-4 bg-white border border-gray-100 rounded-xl p-3 shadow-2xs">
                    <img src="${item.img}" alt="${item.name}" class="w-16 h-16 object-cover bg-gray-50 rounded-lg border border-gray-100 shrink-0">
                    <div class="flex-1 min-w-0">
                        <h4 class="font-bold text-gray-900 text-sm truncate">${item.name}</h4>
                        <p class="text-xs text-gray-500 mt-0.5">₹${item.price} each</p>
                        <p class="text-sm text-indigo-600 font-bold mt-1">₹${(item.price * item.quantity).toLocaleString('en-IN')}</p>
                    </div>
                    <div class="flex items-center border border-gray-200 rounded-lg bg-white overflow-hidden">
                        <button onclick="updateQuantity('${item.name}', -1)" class="px-2 py-1 text-gray-500 hover:bg-gray-100 text-sm cursor-pointer">-</button>
                        <span class="px-2 text-sm font-bold text-gray-800">${item.quantity}</span>
                        <button onclick="updateQuantity('${item.name}', 1)" class="px-2 py-1 text-gray-500 hover:bg-gray-100 text-sm cursor-pointer">+</button>
                    </div>
                </div>
            `).join('');
        }

        // EmailJS Submission Implementation
        function handleCheckout(e) {
            e.preventDefault();
            const submitBtn = document.getElementById('send-order-btn');
            
            // Build simple formatted string table list from items state
            let itemsStringList = cart.map(item => `- ${item.name} (Qty: ${item.quantity}) - Total: ₹${item.price * item.quantity}`).join('\n');
            const grandTotal = cart.reduce((acc, current) => acc + (current.price * current.quantity), 0);

            // Fetch form fields parameters values
            const templateParams = {
                to_email: "pritamsen850@gmail.com",
                customer_name: document.getElementById('cust-name').value,
                customer_phone: document.getElementById('cust-phone').value,
                customer_email: document.getElementById('cust-email').value,
                delivery_address: document.getElementById('cust-address').value,
                delivery_pincode: document.getElementById('cust-pincode').value,
                items_ordered: itemsStringList,
                grand_total: `₹${grandTotal.toLocaleString('en-IN')}`
            };

            // Loading state updates UI
            submitBtn.disabled = true;
            submitBtn.innerHTML = `<i class="fa-solid fa-spinner animate-spin"></i> Processing Order...`;

            /* 
               EmailJS implementation trigger
               Replace placeholders below with actual values inside your EmailJS Account Dashboard:
               Service ID: e.g. "service_xxx"
               Template ID: e.g. "template_xxx"
            */
            emailjs.send('YOUR_SERVICE_ID', 'YOUR_TEMPLATE_ID', templateParams)
                .then(function(response) {
                    alert('🎉 Success! Your order has been placed successfully. The shopkeeper will contact you shortly.');
                    // Reset cart and dynamic fields
                    cart = [];
                    updateCartUI();
                    document.getElementById('order-form').reset();
                    toggleCartDrawer(false);
                }, function(error) {
                    console.error('EmailJS Error Fail:', error);
                    // Notice: Even if EmailJS tokens are unconfigured yet, notify backup alternative step path gracefully
                    alert('Notice: Setup Required! The checkout data form captures perfectly. To complete order delivery integration, configure your real operational EmailJS Keys inside the footer JavaScript block.');
                })
                .finally(() => {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = `<i class="fa-solid fa-paper-plane"></i> Send Order via Email`;
                });
        }
    </script>
</body>
</html>
