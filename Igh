<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pip Pins Apparel - Fresh Finds, Best Price</title>
    <!-- Tailwind CSS for modern styling -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome for clean icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- EmailJS SDK -->
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js"></script>
    <script type="text/javascript">
        // Initialize EmailJS with your Public Key
        // Replace 'YOUR_PUBLIC_KEY' with your actual EmailJS public key from https://www.emailjs.com/
        emailjs.init("YOUR_PUBLIC_KEY");
    </script>
    <style>
        /* Hide scrollbars for the horizontal product carousel */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        /* Smooth scroll behavior */
        html {
            scroll-behavior: smooth;
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 font-sans antialiased">

    <!-- Header / Navbar -->
    <header class="sticky top-0 z-40 bg-white shadow-sm border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            <div>
                <h1 class="text-xl font-bold tracking-tight text-indigo-600">Pip Pins Apparel</h1>
                <p class="text-xs text-gray-500 italic">Fresh Finds, Best Price</p>
            </div>
            <!-- Cart Icon -->
            <button 
                onclick="toggleCart(true)" 
                class="relative p-2 bg-indigo-50 text-indigo-600 hover:bg-indigo-100 rounded-full transition-all"
                aria-label="Open shopping cart"
                title="View Cart">
                <i class="fa-solid fa-basket-shopping text-xl"></i>
                <span 
                    id="cart-count" 
                    class="absolute -top-1 -right-1 bg-red-500 text-white text-xs w-5 h-5 rounded-full flex items-center justify-center font-bold shadow-sm"
                    aria-label="Cart items count">
                    0
                </span>
            </button>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="relative w-full h-[65vh] md:h-[80vh] flex items-center justify-center bg-gray-900 overflow-hidden">
        <img src="https://i.ibb.co/xtCpqt12/Picsart-26-07-11-03-30-22-015.jpg" alt="Pip Pins Apparel Hero Banner" class="absolute inset-0 w-full h-full object-cover opacity-60">
        <div class="relative z-10 text-center px-4 sm:px-6 max-w-3xl">
            <h2 class="text-4xl md:text-6xl font-extrabold text-white tracking-tight drop-shadow-md">Elevate Your Daily Style</h2>
            <p class="mt-4 text-lg md:text-xl text-gray-200 drop-shadow-sm font-medium">Fresh Finds, Best Price. Curated fits ready for your wardrobe.</p>
            <a href="#products-section" class="mt-8 inline-block bg-white text-indigo-600 font-semibold px-8 py-3 rounded-full shadow-lg hover:bg-indigo-50 hover:scale-105 transition-all duration-300">
                Shop Now <i class="fa-solid fa-arrow-down ml-2"></i>
            </a>
        </div>
    </section>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12" id="products-section">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-2xl font-bold tracking-tight text-gray-900">Featured Collection</h3>
            <span class="text-sm text-gray-500 hidden sm:block">Swipe to view all <i class="fa-solid fa-arrow-right ml-1"></i></span>
        </div>

        <!-- Horizontal Product Carousel -->
        <div id="product-carousel" class="flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory no-scrollbar scroll-smooth" role="region" aria-label="Product carousel">
            <!-- Products will be generated by JS dynamically -->
        </div>
    </main>

    <!-- Cart Drawer Modal Overlay -->
    <div id="cart-drawer" class="fixed inset-0 z-50 invisible transition-all duration-300" role="dialog" aria-label="Shopping cart drawer">
        <div onclick="toggleCart(false)" class="absolute inset-0 bg-black/50 backdrop-blur-sm transition-opacity"></div>
        <div class="absolute right-0 top-0 bottom-0 w-full max-w-md bg-white shadow-2xl flex flex-col transform translate-x-full transition-transform duration-300 h-full">
            
            <!-- Drawer Header -->
            <div class="p-4 border-b flex justify-between items-center bg-gray-50">
                <h3 class="text-lg font-bold text-gray-900 flex items-center gap-2">
                    <i class="fa-solid fa-cart-shopping text-indigo-600"></i> Your Shopping Bag
                </h3>
                <button 
                    onclick="toggleCart(false)" 
                    class="text-gray-400 hover:text-gray-600 p-1"
                    aria-label="Close cart drawer">
                    <i class="fa-solid fa-xmark text-xl"></i>
                </button>
            </div>

            <!-- Drawer Content (Scrollable) -->
            <div class="flex-1 overflow-y-auto p-4 space-y-4" id="cart-items-container">
                <!-- Cart items load here -->
            </div>

            <!-- Drawer Footer / Checkout Form -->
            <div class="border-t bg-gray-50 p-4 shadow-inner">
                <div class="flex justify-between items-center mb-4">
                    <span class="text-gray-600 font-medium">Estimated Total:</span>
                    <span id="cart-total" class="text-xl font-bold text-indigo-600">₹0.00</span>
                </div>

                <!-- Customer Details Form -->
                <form id="order-form" onsubmit="handleCheckout(event)" class="space-y-3 bg-white p-3 rounded-lg border border-gray-200">
                    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Delivery Information</p>
                    <input type="text" id="cust-name" placeholder="Full Name" required class="w-full text-sm px-3 py-2 border rounded focus:outline-none focus:ring-1 focus:ring-indigo-500">
                    <input type="tel" id="cust-phone" placeholder="Mobile Number" required class="w-full text-sm px-3 py-2 border rounded focus:outline-none focus:ring-1 focus:ring-indigo-500">
                    <input type="email" id="cust-email" placeholder="Your Email ID" required class="w-full text-sm px-3 py-2 border rounded focus:outline-none focus:ring-1 focus:ring-indigo-500">
                    <input type="text" id="cust-pincode" placeholder="Pincode" required class="w-full text-sm px-3 py-2 border rounded focus:outline-none focus:ring-1 focus:ring-indigo-500">
                    <textarea id="cust-address" placeholder="Complete Shipping Address" rows="2" required class="w-full text-sm px-3 py-2 border rounded focus:outline-none focus:ring-1 focus:ring-indigo-500"></textarea>

                    <button type="submit" class="w-full mt-2 bg-indigo-600 text-white font-medium py-2.5 rounded shadow hover:bg-indigo-700 transition-colors flex items-center justify-center gap-2">
                        <i class="fa-solid fa-paper-plane"></i> Send Order via Email
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Floating Cart Badge (Mobile) -->
    <button 
        onclick="toggleCart(true)" 
        class="fixed bottom-24 right-6 z-40 bg-indigo-600 text-white p-4 rounded-full shadow-2xl hover:bg-indigo-700 hover:scale-110 transition-all md:hidden"
        aria-label="Open shopping cart"
        title="View Cart">
        <i class="fa-solid fa-cart-shopping text-xl"></i>
        <span 
            id="floating-cart-count" 
            class="absolute -top-1 -right-1 bg-red-500 text-white text-xs w-5 h-5 rounded-full flex items-center justify-center font-bold"
            aria-label="Cart items count">
            0
        </span>
    </button>

    <!-- Floating WhatsApp Button -->
    <a href="https://wa.me/7449597053?text=Hi%20Pip%20Pins%20Apparel!%20I'm%20interested%20in%20your%20products." 
       target="_blank" 
       rel="noopener noreferrer"
       class="fixed bottom-6 right-6 z-40 bg-emerald-500 text-white p-4 rounded-full shadow-2xl hover:bg-emerald-600 hover:scale-110 transition-all flex items-center justify-center"
       title="Chat on WhatsApp"
       aria-label="Contact us on WhatsApp">
        <i class="fa-brands fa-whatsapp text-2xl"></i>
    </a>

    <!-- Footer Information -->
    <footer class="bg-gray-900 text-gray-400 py-8 border-t border-gray-800 text-center text-sm">
        <p class="font-semibold text-white">Pip Pins Apparel</p>
        <p class="text-xs mt-1">Owner Contact: pritamsen850@gmail.com</p>
        <p class="mt-4 text-xs text-gray-600">&copy; 2026 Pip Pins Apparel. All Rights Reserved.</p>
    </footer>

    <!-- App Logic Scripts -->
    <script>
        // Real Mock Product Data
        const products = [
            { id: 1, name: "Urban Street Tee", price: 899, img: "https://i.ibb.co/3YM0cY9f/AISelect-20260712-155246.jpg" },
            { id: 2, name: "Vintage Oversized Fit", price: 1199, img: "https://i.ibb.co/LDqvs4nv/AISelect-20260714-203130.jpg" },
            { id: 3, name: "Classic Pins Jacket", price: 2499, img: "https://i.ibb.co/qLynHsBm/AISelect-20260712-164410.jpg" },
            { id: 4, name: "Streetwear Cargo Edition", price: 1599, img: "https://i.ibb.co/WpxZ7GBn/1d1a2b4057641bdfaad0447bbda3725b.jpg" }
        ];

        let cart = [];

        // Dynamic Product Generation for the Carousel
        const carousel = document.getElementById('product-carousel');
        
        function initializeCarousel() {
            carousel.innerHTML = ''; // Clear previous items
            
            products.forEach(product => {
                const card = document.createElement('div');
                card.className = "min-w-[280px] sm:min-w-[300px] bg-white rounded-xl shadow-md overflow-hidden border border-gray-100 snap-center flex flex-col justify-between transform hover:-translate-y-1 transition-transform duration-300";
                card.innerHTML = `
                    <div>
                        <div class="relative w-full h-72 bg-gray-100">
                            <img src="${product.img}" alt="${product.name}" class="w-full h-full object-cover" loading="lazy">
                        </div>
                        <div class="p-4">
                            <h4 class="font-bold text-gray-900 text-base line-clamp-1">${product.name}</h4>
                            <p class="text-indigo-600 font-extrabold text-lg mt-1">₹${product.price.toLocaleString('en-IN')}</p>
                        </div>
                    </div>
                    <div class="p-4 pt-0">
                        <button onclick="addToCart(${product.id})" class="w-full bg-indigo-50 text-indigo-600 hover:bg-indigo-600 hover:text-white font-medium py-2 rounded-lg transition-all flex items-center justify-center gap-2">
                            <i class="fa-solid fa-plus text-xs"></i> Add to Cart
                        </button>
                    </div>
                `;
                carousel.appendChild(card);
            });
        }

        // Initialize carousel on page load
        document.addEventListener('DOMContentLoaded', initializeCarousel);

        // Cart Drawer Toggle Function
        function toggleCart(open) {
            const drawer = document.getElementById('cart-drawer');
            const inner = drawer.querySelector('.absolute.right-0');
            if(open) {
                drawer.classList.remove('invisible');
                setTimeout(() => inner.classList.remove('translate-x-full'), 10);
            } else {
                inner.classList.add('translate-x-full');
                setTimeout(() => drawer.classList.add('invisible'), 300);
            }
        }

        // Add Product to Cart
        function addToCart(productId) {
            const product = products.find(p => p.id === productId);
            if (!product) return;
            
            const trackingItem = cart.find(item => item.id === productId);

            if(trackingItem) {
                trackingItem.quantity += 1;
            } else {
                cart.push({ ...product, quantity: 1 });
            }
            renderCart();
            toggleCart(true); // Auto-open cart on add
        }

        // Update Quantity
        function updateQuantity(id, change) {
            const item = cart.find(i => i.id === id);
            if (!item) return;
            
            item.quantity += change;
            if(item.quantity <= 0) {
                cart = cart.filter(i => i.id !== id);
            }
            renderCart();
        }

        // Render Cart UI
        function renderCart() {
            const container = document.getElementById('cart-items-container');
            const totalCountEl = document.getElementById('cart-count');
            const floatingCountEl = document.getElementById('floating-cart-count');
            const totalCostEl = document.getElementById('cart-total');

            container.innerHTML = "";
            let totalItems = 0;
            let totalCost = 0;

            if(cart.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-12 text-gray-400">
                        <i class="fa-solid fa-basket-shopping text-4xl mb-2 block"></i>
                        <p class="text-sm">Your cart is currently empty.</p>
                    </div>
                `;
            } else {
                cart.forEach(item => {
                    totalItems += item.quantity;
                    totalCost += (item.price * item.quantity);

                    const cartItem = document.createElement('div');
                    cartItem.className = "flex items-center gap-3 bg-gray-50 p-2 rounded-lg border";
                    cartItem.innerHTML = `
                        <img src="${item.img}" alt="${item.name}" class="w-16 h-16 object-cover rounded bg-white border" loading="lazy">
                        <div class="flex-1">
                            <h5 class="text-sm font-bold text-gray-900 line-clamp-1">${item.name}</h5>
                            <p class="text-xs text-indigo-600 font-semibold mt-0.5">₹${item.price}</p>
                            <div class="flex items-center justify-between mt-1">
                                <div class="flex items-center border bg-white rounded">
                                    <button onclick="updateQuantity(${item.id}, -1)" class="px-2 py-0.5 text-gray-500 hover:bg-gray-100 text-xs" aria-label="Decrease quantity">-</button>
                                    <span class="px-2 text-xs font-semibold">${item.quantity}</span>
                                    <button onclick="updateQuantity(${item.id}, 1)" class="px-2 py-0.5 text-gray-500 hover:bg-gray-100 text-xs" aria-label="Increase quantity">+</button>
                                </div>
                            </div>
                        </div>
                    `;
                    container.appendChild(cartItem);
                });
            }

            totalCountEl.innerText = totalItems;
            floatingCountEl.innerText = totalItems;
            totalCostEl.innerText = `₹${totalCost.toLocaleString('en-IN')}`;
        }

        // EmailJS Order Submission
        function handleCheckout(event) {
            event.preventDefault();

            if(cart.length === 0) {
                alert("Your shopping cart is empty!");
                return;
            }

            // Get form values
            const name = document.getElementById('cust-name').value.trim();
            const phone = document.getElementById('cust-phone').value.trim();
            const email = document.getElementById('cust-email').value.trim();
            const pincode = document.getElementById('cust-pincode').value.trim();
            const address = document.getElementById('cust-address').value.trim();

            // Validate form
            if (!name || !phone || !email || !pincode || !address) {
                alert("Please fill in all required fields!");
                return;
            }

            // Format items list
            let itemListString = cart.map(item => `${item.name} (Qty: ${item.quantity}) - Price: ₹${item.price * item.quantity}`).join('\n');
            let grandTotal = document.getElementById('cart-total').innerText;

            // Prepare template parameters
            const templateParams = {
                to_email: "pritamsen850@gmail.com",
                customer_name: name,
                customer_phone: phone,
                customer_email: email,
                customer_pincode: pincode,
                customer_address: address,
                item_list: itemListString,
                grand_total: grandTotal
            };

            // Send email via EmailJS
            emailjs.send('YOUR_SERVICE_ID', 'YOUR_TEMPLATE_ID', templateParams)
                .then(function(response) {
                    alert(`✨ Order Sent Successfully!\nThank you, ${name}. Pip Pins Apparel will process your order soon.`);
                    // Reset cart and form
                    cart = [];
                    renderCart();
                    document.getElementById('order-form').reset();
                    toggleCart(false);
                }, function(error) {
                    console.error('EmailJS Error:', error);
                    alert("Order processed locally! Configure your EmailJS Service & Template IDs in the code to receive notifications seamlessly.\n\nSetup Guide:\n1. Go to emailjs.com and create an account\n2. Add an email service and copy your Service ID\n3. Create an email template and copy your Template ID\n4. Replace YOUR_PUBLIC_KEY, YOUR_SERVICE_ID, and YOUR_TEMPLATE_ID in this file");
                });
        }

        // Initialize cart on page load
        document.addEventListener('DOMContentLoaded', () => {
            renderCart();
        });
    </script>
</body>
</html>
